---
import Section from "./Section.astro";

const metrics = [
  { value: "<60s", label: "Average Lead Response Time" },
  { value: "2.5×", label: "More Booked Appointments" },
  { value: "7 Days", label: "From Signup to Fully Live" },
];
---

<Section id="metrics">
  <div class="bg-black rounded-3xl py-12 px-8 mb-20 text-white shadow-2xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center divide-y md:divide-y-0 md:divide-x divide-zinc-700">
      {metrics.map((metric) => (
        <div class="px-4 py-4 md:py-0 flex flex-col items-center justify-center">
          <h2 class="text-5xl md:text-6xl font-bold text-white mb-4 tracking-tight">{metric.value}</h2>
          <p class="text-lg md:text-xl text-zinc-300 font-medium max-w-xs">{metric.label}</p>
        </div>
      ))}
    </div>
  </div>
</Section>
